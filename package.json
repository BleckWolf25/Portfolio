{
  "name": "portfolio",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck":"vue-tsc --noEmit",
    "lint":"eslint . --ext .ts,.vue,.js",
    "lint:fix":"eslint . --ext .ts,.vue,.js --fix",
    "format":"prettier --write .",
    "test":"vitest",
    "test:coverage":"c8 pnpm vitest --coverage",
    "prepare":"husky install",
    "precommit":"pnpm -s lint-staged",
    "prepush":"pnpm -s test"
  },
  "dependencies": {
    "@nuxt/ui": "^4.5.0",
    "animejs": "^4.3.6",
    "nuxt": "^4.3.1",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "editorconfig": "^3.0.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^8.0.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "vue-tsc": "^3.2.5"
  }
}
